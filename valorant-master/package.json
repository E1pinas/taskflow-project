{
  "name": "valorant-master",
  "version": "1.0.0",
  "description": "Tema simple de valorant para practicar tailwind",
  "main": "script.js",
  "scripts": {
    "build:css": "tailwindcss -i ./input.css -o ./output.css --minify",
    "watch:css": "tailwindcss -i ./input.css -o ./output.css --watch",
    "serve": "live-server --port=5173 --no-browser",
    "dev": "concurrently \"npm:watch:css\" \"npm:serve\""
  },
  "keywords": [],
  "author": "daichi",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "live-server": "1.2.2",
    "postcss": "8.5.8",
    "tailwindcss": "3.4.17"
  }
}
