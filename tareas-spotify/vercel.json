{
  "version": 2,
  "functions": {
    "server/api/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/server/api/index.js"
    },
    {
      "source": "/api/:match*",
      "destination": "/server/api/index.js"
    }
  ]
}
