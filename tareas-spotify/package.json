{
  "name": "tareas-spotify",
  "version": "1.0.0",
  "description": "Aplicación web simple para gestionar tareas en el navegador usando JavaScript ",
  "main": "server/src/index.js",
  "scripts": {
    "build": "tailwindcss -i ./input.css -o ./output.css --minify",
    "build:css": "tailwindcss -i ./input.css -o ./output.css --minify",
    "watch:css": "tailwindcss -i ./input.css -o ./output.css --watch",
    "dev": "concurrently \"npm:watch:css\" \"npm:server:dev\"",
    "server:dev": "nodemon server/src/index.js",
    "server:start": "node server/src/index.js",
    "start": "node server/src/index.js"
  },
  "keywords": [],
  "author": "Daichi",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "concurrently": "9.2.1",
    "nodemon": "^3.1.10",
    "tailwindcss": "^4.1.13"
  }
}
